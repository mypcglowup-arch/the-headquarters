# ── Server-side only (no VITE_ prefix → never bundled into the client) ──────
# Used by Vite dev proxy + api/anthropic.js (Vercel function) to inject
# x-api-key on outgoing calls to api.anthropic.com. The browser never sees it.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Whisper voice transcription — same server-side pattern.
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ── Browser-safe (VITE_ prefix → bundled into the client) ───────────────────
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id-here

# Mem0 — currently still bundled but proxied via /api/mem0 ; the proxy reuses
# this value server-side. Safe to migrate to MEM0_API_KEY (no VITE_) later.
VITE_MEM0_API_KEY=m0-your-mem0-key-here

# Sentry error monitoring (browser-safe DSN — public by design)
VITE_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
