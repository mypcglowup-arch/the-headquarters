VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id-here

# Server-side only (no VITE_ prefix) — used by Vite proxy + Vercel serverless
# for Whisper voice transcription. NEVER exposed to the browser.
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Mem0 also proxied server-side
VITE_MEM0_API_KEY=m0-your-mem0-key-here

# Sentry error monitoring (browser-safe DSN — public by design)
VITE_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
